# ContentBoost AI — Environment Configuration
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# ── Required ───────────────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional server config ─────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Optional storage config ────────────────────────────────────────────────────
# Path to SQLite database file (auto-created on first run)
DB_FILE=data/contentboost.db
MAX_HISTORY_PER_PRODUCT=50

# ── Optional performance config ────────────────────────────────────────────────
# LLM call timeout in seconds
LLM_TIMEOUT=30
# Max requests per minute per IP (rate limiting)
RATE_LIMIT=20
